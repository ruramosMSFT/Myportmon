<Window x:Class="PortMonitor.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortMonitor v1.0 — Real-time Port Monitor"
        Height="680" Width="1200" MinHeight="400" MinWidth="800"
        Background="{DynamicResource BgPrimaryBrush}"
        Icon="pack://application:,,,/app.ico"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- ══ Toolbar ═══════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Filter -->
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox x:Name="FilterBox"
                         Width="200"
                         VerticalAlignment="Center"
                         ToolTip="Filter by IP, port, process name or state"
                         TextChanged="FilterBox_TextChanged" />

                <Button Content="✕" Margin="2,0,8,0" Padding="4,2"
                        ToolTip="Clear filter"
                        Click="ClearFilter_Click" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Background="{DynamicResource BorderBrush}" Margin="6,0" />

                <!-- Settings -->
                <Button Content="⚙ Settings"
                        Margin="2,0"
                        Padding="8,3"
                        Click="Settings_Click"
                        ToolTip="Application settings" />

            </WrapPanel>
        </Border>

        <!-- ══ Status bar ════════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusConnections" Text="Connections: 0" />
            </StatusBarItem>
            <Separator Background="{DynamicResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusRefresh" Text="Last refresh: —" />
            </StatusBarItem>
            <Separator Background="{DynamicResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusAdmin" Text="" />
            </StatusBarItem>
            <Separator Background="{DynamicResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusFilter" Text="" />
            </StatusBarItem>
            <StatusBarItem DockPanel.Dock="Right"
                           HorizontalContentAlignment="Right"
                           Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CPU: "
                               Foreground="{DynamicResource FgMutedBrush}" />
                    <TextBlock x:Name="StatusCpu"
                               Text="&#x2026;"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               ToolTip="App CPU usage" />
                    <TextBlock Text="  Mem: "
                               Foreground="{DynamicResource FgMutedBrush}" />
                    <TextBlock x:Name="StatusMem"
                               Text="&#x2026;"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               ToolTip="App private memory (working set)" />
                    <TextBlock Text="  IP: "
                               Foreground="{DynamicResource FgMutedBrush}" />
                    <TextBlock x:Name="StatusPublicIp"
                               Text="…"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               ToolTip="Your public IP address" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ══ State filter strip ═════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,3">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="State Filter:" VerticalAlignment="Center"
                           Foreground="{DynamicResource FgMutedBrush}"
                           FontSize="11" Margin="0,0,8,0" />
                <ToggleButton x:Name="BtnNew"
                              Content="■ NEW"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorNew}"
                              Foreground="{DynamicResource FgNew}"
                              Tag="New" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show only NEW connections" />
                <ToggleButton x:Name="BtnClosed"
                              Content="■ CLOSED"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorClosed}"
                              Foreground="{DynamicResource FgClosed}"
                              Tag="Closed" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show only CLOSED connections" />
                <ToggleButton x:Name="BtnListen"
                              Content="■ LISTEN"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorListen}"
                              Foreground="{DynamicResource FgListen}"
                              Tag="Listen" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show only LISTEN ports" />
                <ToggleButton x:Name="BtnEstab"
                              Content="■ ESTABLISHED"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorEstablished}"
                              Foreground="{DynamicResource FgEstablished}"
                              Tag="Established" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show only ESTABLISHED connections" />
                <ToggleButton x:Name="BtnTimeWait"
                              Content="■ TIME_WAIT"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorTimeWait}"
                              Foreground="{DynamicResource FgTimeWait}"
                              Tag="TimeWait" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show TIME_WAIT / CLOSE_WAIT connections" />
                <ToggleButton x:Name="BtnUdp"
                              Content="■ UDP"
                              Style="{StaticResource StateFilterButton}"
                              Background="{DynamicResource ColorUdp}"
                              Foreground="{DynamicResource FgUdp}"
                              Tag="Udp" Click="StateFilter_Click" Margin="2,1"
                              ToolTip="Filter: show only UDP endpoints" />
            </WrapPanel>
        </Border>

        <!-- ══ Connection DataGrid ═══════════════════════════════════════════ -->
        <DataGrid x:Name="ConnectionGrid"
                  Margin="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag"
                                    Binding="{Binding Tag}"
                                    Width="48"
                                    FontWeight="Bold" />
                <DataGridTextColumn Header="Proto"
                                    Binding="{Binding Protocol}"
                                    Width="50" />
                <DataGridTextColumn Header="Local Address"
                                    Binding="{Binding LocalAddress}"
                                    Width="140" />
                <DataGridTextColumn Header="L.Port"
                                    Binding="{Binding LocalPort}"
                                    Width="65"
                                    SortMemberPath="LocalPort" />
                <DataGridTextColumn Header="Remote Address"
                                    Binding="{Binding RemoteAddress}"
                                    Width="140" />
                <DataGridTextColumn Header="R.Port"
                                    Binding="{Binding RemotePortDisplay}"
                                    Width="65" />
                <DataGridTextColumn Header="State"
                                    Binding="{Binding StateDisplay}"
                                    Width="110" />
                <DataGridTextColumn Header="PID"
                                    Binding="{Binding Pid}"
                                    Width="65"
                                    SortMemberPath="Pid" />
                <DataGridTextColumn Header="Process"
                                    Binding="{Binding ProcessName}"
                                    Width="140" />
                <DataGridTextColumn x:Name="ColRemoteHost"
                                    Header="Remote Host"
                                    Binding="{Binding RemoteHost}"
                                    Width="*" />
            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>
</Window>
