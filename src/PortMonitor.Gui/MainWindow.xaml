<Window x:Class="PortMonitor.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortMonitor v1.0 — Real-time Port Monitor"
        Height="680" Width="1200" MinHeight="400" MinWidth="800"
        Background="{StaticResource BgPrimaryBrush}"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- ══ Toolbar ═══════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Filter -->
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox x:Name="FilterBox"
                         Width="200"
                         VerticalAlignment="Center"
                         ToolTip="Filter by IP, port, process name or state"
                         TextChanged="FilterBox_TextChanged" />

                <Button Content="✕" Margin="2,0,8,0" Padding="4,2"
                        ToolTip="Clear filter"
                        Click="ClearFilter_Click" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Background="{StaticResource BorderBrush}" Margin="2,0" />

                <!-- View mode -->
                <TextBlock Text="View:" VerticalAlignment="Center" Margin="6,0,4,0" />

                <ToggleButton x:Name="BtnAll" Content="All"
                              IsChecked="True"
                              Margin="2,0"
                              Click="ViewAll_Click"
                              ToolTip="Show all connections" />

                <ToggleButton x:Name="BtnListen" Content="Listen"
                              Margin="2,0"
                              Click="ViewListen_Click"
                              ToolTip="Show only LISTEN ports" />

                <ToggleButton x:Name="BtnEstab" Content="ESTAB"
                              Margin="2,0"
                              Click="ViewEstab_Click"
                              ToolTip="Show only ESTABLISHED connections" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Background="{StaticResource BorderBrush}" Margin="6,0" />

                <!-- Sort -->
                <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox x:Name="SortCombo"
                          Width="110"
                          VerticalAlignment="Center"
                          SelectionChanged="SortCombo_Changed"
                          ToolTip="Sort the connection list">
                    <ComboBoxItem Content="L.Port"   IsSelected="True" />
                    <ComboBoxItem Content="PID" />
                    <ComboBoxItem Content="State" />
                    <ComboBoxItem Content="Process" />
                </ComboBox>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Background="{StaticResource BorderBrush}" Margin="6,0" />

                <!-- Interval -->
                <TextBlock Text="Refresh:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox x:Name="IntervalCombo"
                          Width="60"
                          VerticalAlignment="Center"
                          SelectionChanged="IntervalCombo_Changed"
                          ToolTip="Auto-refresh interval">
                    <ComboBoxItem Content="1 s" />
                    <ComboBoxItem Content="2 s" IsSelected="True" />
                    <ComboBoxItem Content="5 s" />
                    <ComboBoxItem Content="10 s" />
                </ComboBox>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Background="{StaticResource BorderBrush}" Margin="6,0" />

                <!-- Actions -->
                <Button Content="↺ Reset"
                        Margin="2,0"
                        Click="Reset_Click"
                        ToolTip="Reset filter, sort, and view mode" />

                <Button Content="⚙ Prereqs"
                        Margin="2,0"
                        Click="Prereqs_Click"
                        ToolTip="Check prerequisites and install missing components" />

                <Button Content="🎨 Colors"
                        Margin="2,0"
                        Click="Colors_Click"
                        ToolTip="Customize application colors" />

            </WrapPanel>
        </Border>

        <!-- ══ Status bar ════════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusConnections" Text="Connections: 0" />
            </StatusBarItem>
            <Separator Background="{StaticResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusRefresh" Text="Last refresh: —" />
            </StatusBarItem>
            <Separator Background="{StaticResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusAdmin" Text="" />
            </StatusBarItem>
            <Separator Background="{StaticResource BorderBrush}" />
            <StatusBarItem>
                <TextBlock x:Name="StatusFilter" Text="" />
            </StatusBarItem>
        </StatusBar>

        <!-- ══ Legend strip ══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,2">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,12,0">
                    <Run Foreground="{StaticResource FgNew}"         Text="■ NEW  " />
                    <Run Foreground="{StaticResource FgClosed}"      Text="■ CLOSED  " />
                    <Run Foreground="{StaticResource FgListen}"      Text="■ LISTEN  " />
                    <Run Foreground="{StaticResource FgEstablished}" Text="■ ESTABLISHED  " />
                    <Run Foreground="{StaticResource FgTimeWait}"    Text="■ TIME_WAIT / CLOSE_WAIT  " />
                    <Run Foreground="{StaticResource FgUdp}"         Text="■ UDP" />
                </TextBlock>
            </WrapPanel>
        </Border>

        <!-- ══ Connection DataGrid ═══════════════════════════════════════════ -->
        <DataGrid x:Name="ConnectionGrid"
                  Margin="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag"
                                    Binding="{Binding Tag}"
                                    Width="48"
                                    FontWeight="Bold" />
                <DataGridTextColumn Header="Proto"
                                    Binding="{Binding Protocol}"
                                    Width="50" />
                <DataGridTextColumn Header="Local Address"
                                    Binding="{Binding LocalAddress}"
                                    Width="140" />
                <DataGridTextColumn Header="L.Port"
                                    Binding="{Binding LocalPort}"
                                    Width="65"
                                    SortMemberPath="LocalPort" />
                <DataGridTextColumn Header="Remote Address"
                                    Binding="{Binding RemoteAddress}"
                                    Width="140" />
                <DataGridTextColumn Header="R.Port"
                                    Binding="{Binding RemotePortDisplay}"
                                    Width="65" />
                <DataGridTextColumn Header="State"
                                    Binding="{Binding StateDisplay}"
                                    Width="110" />
                <DataGridTextColumn Header="PID"
                                    Binding="{Binding Pid}"
                                    Width="65"
                                    SortMemberPath="Pid" />
                <DataGridTextColumn Header="Process"
                                    Binding="{Binding ProcessName}"
                                    Width="*" />
            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>
</Window>
