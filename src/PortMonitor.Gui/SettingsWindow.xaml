<Window x:Class="PortMonitor.Gui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortMonitor — Color Settings"
        Width="460" Height="650"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#FF2D2D30"
        Foreground="#FFD4D4D4">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Color rows built in code-behind -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Background="#FF2D2D30">
            <StackPanel x:Name="ColorPanel" Margin="16,12,16,8" />
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0" BorderBrush="#FF555555"
                Background="#FF1E1E1E" Padding="12,8">
            <DockPanel>
                <Button Content="Reset Defaults" DockPanel.Dock="Left"
                        Click="ResetDefaults_Click"
                        Background="#FF3E3E42" Foreground="#FFD4D4D4"
                        BorderBrush="#FF666666" BorderThickness="1"
                        Padding="10,5" Cursor="Hand"
                        ToolTip="Restore all colors to original defaults" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click"
                            Margin="0,0,8,0"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4"
                            BorderBrush="#FF666666" BorderThickness="1"
                            Padding="10,5" Cursor="Hand"
                            ToolTip="Discard changes and revert colors" />
                    <Button Content="Apply &amp; Save" Click="Apply_Click"
                            Background="#FF007ACC" Foreground="White"
                            BorderBrush="#FF005A99" BorderThickness="1"
                            Padding="14,5" Cursor="Hand"
                            ToolTip="Save colors and close" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
