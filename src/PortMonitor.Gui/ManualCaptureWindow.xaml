<Window x:Class="PortMonitor.Gui.ManualCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manual Capture"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgPrimaryBrush}">

    <StackPanel Margin="0">

        <!-- Header -->
        <TextBlock Text="Packet Capture (pktmon)"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   Margin="16,14,16,4" />
        <TextBlock Text="Configure IP and/or port filters. Leave both empty to capture all traffic."
                   FontSize="10" FontStyle="Italic"
                   Foreground="{DynamicResource FgMutedBrush}"
                   Margin="16,0,16,10" TextWrapping="Wrap" />

        <!-- Separator -->
        <Border Height="1" Background="{DynamicResource BorderBrush}" />

        <!-- Filters -->
        <TextBlock Text="Filters"
                   FontWeight="SemiBold" FontSize="11"
                   Foreground="{DynamicResource FgMutedBrush}"
                   Margin="16,10,16,4" />
        <Border Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1" Padding="12,8">
            <StackPanel>
                <TextBlock Text="Destination IP:" Margin="0,0,0,4" FontSize="11"
                           Foreground="{DynamicResource FgMutedBrush}" FontFamily="Consolas" />
                <TextBox x:Name="TxtIp"
                         FontFamily="Consolas" FontSize="12"
                         ToolTip="IP address to filter on (leave empty for any)" />

                <TextBlock Text="Destination Port:" Margin="0,10,0,4" FontSize="11"
                           Foreground="{DynamicResource FgMutedBrush}" FontFamily="Consolas" />
                <TextBox x:Name="TxtPort"
                         FontFamily="Consolas" FontSize="12"
                         ToolTip="Port number to filter on (leave empty for any)" />

                <TextBlock Text="Both fields are optional. IP and port form an AND filter."
                           Margin="0,8,0,0" FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource FgMutedBrush}" TextWrapping="Wrap" />
                <TextBlock Text="Leave both empty to capture all machine traffic."
                           Margin="0,2,0,0" FontSize="10" FontStyle="Italic"
                           Foreground="#FFFFD700" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8,0,0" />

        <!-- Status -->
        <TextBlock x:Name="TxtStatus" Text=""
                   FontSize="11" FontFamily="Consolas"
                   Foreground="#FF00DDDD"
                   Margin="16,8,16,4" TextWrapping="Wrap" />

        <!-- Buttons -->
        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10,16,12">
            <Button x:Name="BtnStartCapture"
                    Content="▶ Start Capture"
                    Padding="14,6" Margin="0,0,8,0"
                    Click="StartCapture_Click"
                    ToolTip="Start packet capture with the configured filters" />
            <Button x:Name="BtnStopCapture"
                    Content="⏹ Stop Capture"
                    Padding="14,6" Margin="0,0,8,0"
                    Click="StopCapture_Click"
                    ToolTip="Stop the running capture" />
            <Button Content="Close"
                    Padding="14,6"
                    Click="Close_Click" />
        </StackPanel>

    </StackPanel>
</Window>
